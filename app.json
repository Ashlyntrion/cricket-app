{
  "expo": {
    "name": "Cricket Coach",
    "slug": "cricket_app",
    "version": "1.0.0",
    "scheme": "cricketcoach",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a6b3c"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cricketcoach.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a6b3c",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.cricketcoach.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a6b3c",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "router": {}
    }
  }
}
